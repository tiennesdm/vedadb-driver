{
  "name": "vedadb-driver",
  "version": "1.0.0",
  "description": "Official VedaDB database driver - TCP and HTTP REST API clients for Node.js, Bun, Deno, and browsers",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./api": {
      "import": {
        "types": "./dist/api.d.ts",
        "default": "./dist/api.mjs"
      },
      "require": {
        "types": "./dist/api.d.ts",
        "default": "./dist/api.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/api.ts --format cjs,esm --dts --clean --out-dir dist",
    "prepublishOnly": "npm run build",
    "test": "node --test dist/*.test.js",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "vedadb",
    "database",
    "driver",
    "sql",
    "client",
    "tcp",
    "rest",
    "api",
    "typescript",
    "nodejs",
    "browser"
  ],
  "author": "shubhammehta5407 <shubhammehta5407@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tiennesdm/vedadb-driver.git"
  },
  "bugs": {
    "url": "https://github.com/tiennesdm/vedadb-driver/issues"
  },
  "homepage": "https://github.com/tiennesdm/vedadb-driver#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0"
  }
}
