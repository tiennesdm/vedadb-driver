{
    "name": "vedadb/vedadb",
    "description": "Official PHP driver for VedaDB - The Multi-Model Database Engine",
    "version": "0.2.0",
    "type": "library",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "VedaDB Contributors"
        }
    ],
    "require": {
        "php": ">=8.0",
        "ext-json": "*",
        "ext-sockets": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "VedaDB\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VedaDB\\Tests\\": "tests/"
        }
    },
    "keywords": [
        "vedadb", "database", "multi-model", "sql", "nosql", "cache", "search", "driver"
    ],
    "homepage": "https://github.com/vedadb/vedadb",
    "support": {
        "issues": "https://github.com/vedadb/vedadb/issues",
        "source": "https://github.com/vedadb/vedadb/tree/main/drivers/php"
    }
}
